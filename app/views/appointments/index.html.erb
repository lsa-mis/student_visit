<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold">Appointments</h1>
      <p class="text-gray-600 mt-1">
        Program: <%= link_to @program.name, department_program_path(@department, @program), class: "text-blue-600 hover:text-blue-800" %>
      </p>
    </div>
    <div class="flex items-center gap-4">
      <% if policy(Appointment.new(program: @program)).index? %>
        <div class="relative" data-controller="dropdown">
          <div class="inline-flex rounded-lg overflow-hidden shadow-sm border border-gray-300 bg-white">
            <%= link_to export_department_program_appointments_path(@department, @program, scope: "scheduled", format: :csv),
                        class: "inline-flex items-center gap-1.5 px-4 py-2.5 text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 border-r border-gray-300" do %>
              <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Download CSV (Scheduled)
            <% end %>
            <button type="button"
                    class="inline-flex items-center px-2 py-2.5 text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-gray-300"
                    data-action="click->dropdown#toggle"
                    aria-label="Choose download scope">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
          </div>
          <div class="hidden absolute right-0 mt-1 w-56 bg-white rounded-lg shadow-lg border border-gray-200 py-1 z-50"
               data-dropdown-target="menu">
            <%= link_to export_department_program_appointments_path(@department, @program, scope: "all", format: :csv),
                        class: "block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-100" do %>
              All appointments
            <% end %>
            <%= link_to export_department_program_appointments_path(@department, @program, scope: "scheduled", format: :csv),
                        class: "block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-100" do %>
              Scheduled only
            <% end %>
          </div>
        </div>
      <% end %>
      <% if @can_create_appointments %>
        <div class="flex space-x-2">
          <%= link_to "Bulk Upload", bulk_upload_department_program_appointments_path(@department, @program), class: "bg-purple-600 text-white btn-responsive rounded hover:bg-purple-700" %>
          <%= link_to "Schedule Builder", schedule_builder_department_program_appointments_path(@department, @program), class: "bg-blue-600 text-white btn-responsive rounded hover:bg-blue-700" %>
          <%= link_to "New Appointment", new_department_program_appointment_path(@department, @program), class: "bg-green-600 text-white btn-responsive rounded hover:bg-green-700" %>
        </div>
      <% end %>
    </div>
  </div>

  <% if flash[:notice] %>
    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded mb-4">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <% if flash[:alert] %>
    <div class="bg-yellow-50 border border-yellow-200 text-yellow-700 px-4 py-3 rounded mb-4">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <% if flash[:errors] && flash[:errors].any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded mb-4">
      <h3 class="font-bold mb-2">Errors:</h3>
      <ul class="list-disc list-inside">
        <% flash[:errors].each do |error| %>
          <li><%= error %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

<%= render "shared/page_instructions",
      page_path: "appointments/index",
      default_text: "Click 'View' on any appointment to see more details. Click the 'Edit' button on the appointment details page (blue button at the top) to modify the 'Office Number' field if the meeting is in a different location. Click 'Update Appointment' to save." %>

  <div class="bg-white shadow rounded-lg p-6">
    <% if @appointments.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Faculty</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Start Time</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">End Time</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Office Number</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Student</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
              <% if @can_view_appointments %>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
              <% end %>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @appointments.each do |appointment| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= appointment.vip.display_name %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= appointment.start_time.strftime("%B %d, %Y at %I:%M %p") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= appointment.end_time.strftime("%B %d, %Y at %I:%M %p") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= appointment.office_number.presence || content_tag(:span, "—", class: "text-gray-400") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <% if appointment.student %>
                    <%= appointment.student.email_address %>
                  <% else %>
                    <span class="text-gray-400">Available</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm">
                  <% if appointment.available? %>
                    <span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">Available</span>
                  <% else %>
                    <span class="px-2 py-1 text-xs font-semibold rounded-full bg-blue-100 text-blue-800">Booked</span>
                  <% end %>
                </td>
                <% if @can_view_appointments %>
                  <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                    <%= link_to "View", department_program_appointment_path(@department, @program, appointment), class: "text-indigo-600 hover:text-indigo-800" %>
                  </td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="mt-4 text-sm text-gray-500">
        Total: <%= @appointments.count %> appointment(s)
      </div>
    <% else %>
      <p class="text-gray-500">No appointments for this program.</p>
    <% end %>
  </div>
</div>
