<div class="container mx-auto px-4 py-8">
  <div class="mb-6">
    <h1 class="text-3xl font-bold">Edit Appointment</h1>
    <p class="text-gray-600 mt-1">
      Program: <%= link_to @program.name, department_program_path(@program.department, @program), class: "text-blue-600 hover:text-blue-800" %>
    </p>
  </div>

  <%= render "shared/page_instructions",
      page_path: "appointments/edit",
      default_text: "Edit appointment details. You can change the office location if the meeting is in a different space than the faculty member's office." %>

  <%= form_with model: [@program.department, @program, @appointment], class: "bg-white shadow rounded-lg p-6" do |form| %>
    <% if @appointment.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded mb-4">
        <h2 class="font-bold"><%= pluralize(@appointment.errors.count, "error") %> prohibited this appointment from being saved:</h2>
        <ul class="list-disc list-inside mt-2">
          <% @appointment.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= form.label :vip_id, "Faculty Member", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :vip_id,
          options_from_collection_for_select(@vips, :id, :display_name, @appointment.vip_id),
          { prompt: "Select a faculty member" },
          { required: true, 
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500",
            data: { vip_office_numbers: @vips.index_by(&:id).transform_values(&:office_number).to_json } } %>
    </div>

    <div class="mb-4">
      <%= form.label :office_number, "Office Number", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :office_number, 
          placeholder: "e.g., LSA 3202 or ISR 4184B", 
          value: @appointment.office_number,
          class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
      <p class="text-xs text-gray-500 mt-1">
        Defaults to the faculty member's office number (<%= @appointment.vip&.office_number || "N/A" %>), but can be edited if meeting in a different location.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      <div>
        <%= form.label :start_time, "Start Time", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.datetime_local_field :start_time, 
            value: @appointment.start_time&.strftime("%Y-%m-%dT%H:%M"),
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500", required: true %>
      </div>
      <div>
        <%= form.label :end_time, "End Time", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.datetime_local_field :end_time, 
            value: @appointment.end_time&.strftime("%Y-%m-%dT%H:%M"),
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500", required: true %>
      </div>
    </div>

    <div class="flex justify-end space-x-4">
      <%= form.submit "Update Appointment", class: "bg-blue-600 text-white btn-responsive rounded hover:bg-blue-700" %>
      <%= link_to "Cancel", department_program_appointment_path(@program.department, @program, @appointment), class: "bg-gray-600 text-white btn-responsive rounded hover:bg-gray-700" %>
    </div>
  <% end %>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const vipSelect = document.querySelector('select[name="appointment[vip_id]"]');
      const officeNumberField = document.querySelector('input[name="appointment[office_number]"]');
      
      if (vipSelect && officeNumberField) {
        const officeNumberMap = JSON.parse(vipSelect.dataset.vipOfficeNumbers || '{}');

        vipSelect.addEventListener('change', function() {
          const selectedVipId = this.value;
          if (selectedVipId && officeNumberMap[selectedVipId]) {
            // Only update if the field is currently empty or matches the current VIP's office number
            const currentVipId = '<%= @appointment.vip_id %>';
            if (!officeNumberField.value || officeNumberField.value === officeNumberMap[currentVipId]) {
              officeNumberField.value = officeNumberMap[selectedVipId];
            }
          }
        });
      }
    });
  </script>
</div>
